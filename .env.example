# SUPABASE — Obrigatorio para salvar dados na nuvem
# Obtenha em: https://app.supabase.com -> Settings -> API
VITE_SUPABASE_URL="https://SEU_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="sua_anon_key_aqui"

